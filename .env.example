# Copy this file to `.env` and fill the values. `.env` is gitignored.
# In CI / release builds you can override every value with `--dart-define`.

# ---------------------------------------------------------------------------
# Auth0 (via flutter_appauth - generic OIDC client)
# ---------------------------------------------------------------------------
# 1. Create a "Native" application in your Auth0 dashboard.
# 2. Allowed Callback URLs (one chip per line):
#      com.revosso.revomaket:/oauthredirect
# 3. Allowed Logout URLs: same as Callback URLs.
# 4. If you set AUTH0_AUDIENCE, the corresponding API in Auth0 must have
#    "Allow Offline Access" enabled so refresh tokens are issued.
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_AUDIENCE=https://api.revomaket.com
AUTH0_REDIRECT_URL=com.revosso.revomaket:/oauthredirect

# ---------------------------------------------------------------------------
# WebView
# ---------------------------------------------------------------------------
WEB_BASE_URL=https://revomaket.com

# ---------------------------------------------------------------------------
# Firebase Messaging (web only - native uses google-services.json / plist)
# ---------------------------------------------------------------------------
FIREBASE_VAPID_KEY=
