# Copy this file to `.env` and fill the values. `.env` is gitignored.
# In CI / release builds you can override every value with `--dart-define`.

# ---------------------------------------------------------------------------
# Auth0
# ---------------------------------------------------------------------------
# 1. Create a "Native" application in your Auth0 dashboard.
# 2. Allowed Callback URLs (replace with your domain + bundle id):
#    https://YOUR_TENANT.auth0.com/android/com.brackstechnologies.revomaket/callback,
#    com.brackstechnologies.revomaket://YOUR_TENANT.auth0.com/android/com.brackstechnologies.revomaket/callback,
#    com.brackstechnologies.revomaket://YOUR_TENANT.auth0.com/ios/com.brackstechnologies.revomaket/callback
# 3. Allowed Logout URLs: same as above.
# 4. Enable "Refresh Token Rotation" + "Allow Offline Access" for the API.
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_AUDIENCE=https://api.revomaket.com
AUTH0_SCHEME=com.brackstechnologies.revomaket

# ---------------------------------------------------------------------------
# WebView
# ---------------------------------------------------------------------------
WEB_BASE_URL=https://revomaket.com

# ---------------------------------------------------------------------------
# Firebase Messaging (web only - native uses google-services.json / plist)
# ---------------------------------------------------------------------------
FIREBASE_VAPID_KEY=
